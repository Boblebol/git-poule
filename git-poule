#!/bin/sh

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)

print_happy_chicken() {
  cat <<'CHICKEN'
     \\
      \\  cot cot
       \\
        __
      <(o )___
       ( ._> /
        `---'
CHICKEN
}

print_ko_chicken() {
  cat <<'CHICKEN'
     pull rate
        __
      <(x )___
       ( ._> /
        `---'  KO
CHICKEN
}

find_sound_file() {
  sound_name=$1

  if [ -n "${GIT_POULE_SOUND_DIR:-}" ] && [ -f "$GIT_POULE_SOUND_DIR/$sound_name" ]; then
    printf '%s\n' "$GIT_POULE_SOUND_DIR/$sound_name"
    return 0
  fi

  for sound_dir in \
    "$script_dir/../share/git-poule" \
    "$script_dir/assets/sounds" \
    "$script_dir/../assets/sounds"
  do
    if [ -f "$sound_dir/$sound_name" ]; then
      printf '%s\n' "$sound_dir/$sound_name"
      return 0
    fi
  done

  return 1
}

play_sound_file() {
  sound_file=$1

  if command -v afplay >/dev/null 2>&1; then
    afplay "$sound_file" >/dev/null 2>&1 && return 0
  fi

  if command -v paplay >/dev/null 2>&1; then
    paplay "$sound_file" >/dev/null 2>&1 && return 0
  fi

  if command -v aplay >/dev/null 2>&1; then
    aplay "$sound_file" >/dev/null 2>&1 && return 0
  fi

  return 1
}

fallback_sound() {
  if command -v say >/dev/null 2>&1; then
    say "cot cot cot" >/dev/null 2>&1 || true
  else
    printf '\a' >&2 || true
  fi
}

play_named_sound() {
  sound_name=$1
  sound_file=$(find_sound_file "$sound_name") || {
    fallback_sound
    return 0
  }

  play_sound_file "$sound_file" || fallback_sound
}

git pull "$@"
status=$?

if [ "$status" -ne 0 ]; then
  play_named_sound "poule.wav"
  print_ko_chicken
  exit "$status"
fi

play_named_sound "coq.wav"
print_happy_chicken
