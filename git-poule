#!/bin/sh

print_happy_chicken() {
  cat <<'CHICKEN'
     \\
      \\  cot cot
       \\
        __
      <(o )___
       ( ._> /
        `---'
CHICKEN
}

print_ko_chicken() {
  cat <<'CHICKEN'
     pull rate
        __
      <(x )___
       ( ._> /
        `---'  KO
CHICKEN
}

git pull "$@"
status=$?

if [ "$status" -ne 0 ]; then
  print_ko_chicken
  exit "$status"
fi

if command -v say >/dev/null 2>&1; then
  say "cot cot cot" >/dev/null 2>&1 || true
else
  printf '\a' >&2 || true
fi

print_happy_chicken
